{
  "name": "Pause Card",
  "identifier": "io.github.fahim.pausecard",
  "version": "0.1.13",
  "author": {
    "name": "Fahim"
  },
  "entry": "main.js",
  "description": "A Netflix-style pause overlay for IINA.",
  "permissions": [
    "show-osd",
    "video-overlay",
    "network-request",
    "file-system"
  ],
  "allowedDomains": [
    "api.themoviedb.org"
  ],
  "preferencesPage": "preferences.html",
  "preferenceDefaults": {
    "tmdb_auth": "",
    "metadata_language": "en-US",
    "overlay_enabled": true,
    "pause_delay_seconds": 0.45,
    "synopsis_lines": 4,
    "debug_osd": false
  }
}
